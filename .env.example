# Facebook App credentials (lấy từ developers.facebook.com)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Webhook verify token (tự đặt chuỗi bất kỳ, dùng khi đăng ký webhook với Meta)
WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token

# Session secret (tối thiểu 32 ký tự ngẫu nhiên)
SESSION_SECRET=change_this_to_a_random_32_char_secret_string

# App URL (thay bằng ngrok URL khi test webhook local)
NEXT_PUBLIC_APP_URL=http://localhost:3000
